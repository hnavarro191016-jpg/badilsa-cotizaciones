generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("USER") // ADMIN or USER
  nombre                 String?
  apellido               String?
  telefono               String?
  email                  String?
  estatus                String   @default("ACTIVO") // PENDIENTE, ACTIVO, RECHAZADO
  preguntaSecreta1       String?
  respuestaSecreta1      String?
  preguntaSecreta2       String?
  respuestaSecreta2      String?
  requiresPasswordChange Boolean  @default(true)
  createdAt              DateTime @default(now())
}

model Cotizacion {
  id            String   @id @default(cuid())
  folio         String   @unique
  fecha         String
  atencion      String
  empresa       String
  moneda        String
  observaciones String
  propuesta     String   @default("")
  tiempoEntrega String
  subTotal      Float
  iva           Float
  total         Float
  estatus       String   @default("BORRADOR") // BORRADOR, ENVIADA, ACEPTADA, RECHAZADA
  estatusOC     String   @default("PENDIENTE") // PENDIENTE, RECIBIDA, VALIDADA
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         ItemCotizacion[]
  archivosOC    OrdenCompraArchivo[]
  notasRemision NotaRemision[]
  facturas      Factura[]
}

model ItemCotizacion {
  id             String     @id @default(cuid())
  cotizacionId   String
  cantidad       Float
  unidad         String
  descripcion    String
  precioUnitario Float
  valorDolar     Float      @default(1)
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
}

model OrdenCompraArchivo {
  id            String     @id @default(cuid())
  cotizacionId  String
  nombreArchivo String
  fileData      String     // Base64 del PDF
  fechaSubida   DateTime   @default(now())
  
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
}

model NotaRemision {
  id            String   @id @default(cuid())
  folio         String   @unique
  fecha         String
  condiciones   String
  cliente       String
  direccion     String
  ciudad        String
  rfc           String
  tel           String
  lugarExp      String
  cotizacionId  String?
  cotizacion    Cotizacion? @relation(fields: [cotizacionId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         ItemNotaRemision[]
}

model ItemNotaRemision {
  id               String       @id @default(cuid())
  notaRemisionId   String
  cantidad         Float
  descripcion      String
  notaRemision     NotaRemision @relation(fields: [notaRemisionId], references: [id], onDelete: Cascade)
}

model Factura {
  id               String   @id @default(cuid())
  uuid             String   @unique // Folio Fiscal (UUID del SAT)
  emisorRfc        String
  emisorNombre     String
  receptorRfc      String
  receptorNombre   String
  fechaEmision     DateTime
  fechaVencimiento DateTime // Calculado con los días de crédito
  moneda           String   @default("MXN")
  subTotal         Float
  iva              Float
  total            Float
  estatusPago      String   @default("PENDIENTE") // PENDIENTE, PAGADA, CANCELADA
  cotizacionId     String?  
  cotizacion       Cotizacion? @relation(fields: [cotizacionId], references: [id], onDelete: SetNull)
  xmlData          String?  @db.Text 
  pdfUrl           String?  
  diasCredito      Int      @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
